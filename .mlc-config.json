{
  "ignorePatterns": [
    { "pattern": "^https://example\\.com" },
    { "pattern": "^https://.*\\[.*\\]" },
    { "pattern": "^mailto:" },
    { "pattern": "^tel:" },
    { "pattern": "localhost" }
  ],
  "timeout": "10s",
  "retryOn429": true,
  "retryCount": 2,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 206, 429]
}
